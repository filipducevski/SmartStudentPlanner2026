<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            style="@style/Widget.SmartStudent.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="@dimen/spacing_md"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Exam Title -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilExamTitle"
                style="@style/Widget.SmartStudent.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="@string/exam_title"
                app:startIconDrawable="@drawable/ic_exams">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etExamTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Subject -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/exam_subject"
                android:textAppearance="@style/TextAppearance.SmartStudent.Caption"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_spinner"
                android:padding="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Exam Type chips -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/exam_type"
                android:textAppearance="@style/TextAppearance.SmartStudent.Caption"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.chip.ChipGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWritten"
                    style="@style/Widget.SmartStudent.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exam_type_written"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOral"
                    style="@style/Widget.SmartStudent.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exam_type_oral" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPractical"
                    style="@style/Widget.SmartStudent.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exam_type_practical" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOnline"
                    style="@style/Widget.SmartStudent.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exam_type_online" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Date & Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_md">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectDate"
                    style="@style/Widget.SmartStudent.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/select_date"
                    app:icon="@drawable/ic_calendar" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectTime"
                    style="@style/Widget.SmartStudent.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/select_time"
                    app:icon="@drawable/ic_time" />
            </LinearLayout>

            <!-- Location -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilLocation"
                style="@style/Widget.SmartStudent.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="@string/exam_location"
                app:startIconDrawable="@drawable/ic_location">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Duration -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDuration"
                style="@style/Widget.SmartStudent.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="@string/exam_duration"
                app:startIconDrawable="@drawable/ic_time">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="90"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Reminder -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task_reminder"
                android:textAppearance="@style/TextAppearance.SmartStudent.Caption"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerReminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_spinner"
                android:padding="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Notes -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNotes"
                style="@style/Widget.SmartStudent.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:hint="@string/exam_notes"
                app:startIconDrawable="@drawable/ic_tasks">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:lines="3"
                    android:gravity="top" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Widget.SmartStudent.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/save"
                app:icon="@drawable/ic_tasks" />

            <!-- Delete button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.SmartStudent.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/delete_exam"
                android:textColor="@color/error"
                app:strokeColor="@color/error"
                app:icon="@drawable/ic_warning"
                app:iconTint="@color/error"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
