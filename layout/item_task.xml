<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.SmartStudent.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/card_min_height">

        <!-- Priority color bar -->
        <View
            android:id="@+id/viewPriorityIndicator"
            android:layout_width="@dimen/priority_indicator_width"
            android:layout_height="0dp"
            android:background="@color/priority_medium"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbCompleted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/viewPriorityIndicator"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Task type icon -->
        <ImageView
            android:id="@+id/ivTaskType"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:src="@drawable/ic_homework"
            app:tint="@color/on_surface_variant"
            app:layout_constraintStart_toEndOf="@id/cbCompleted"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="ContentDescription" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:layout_marginTop="@dimen/spacing_md"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="@color/on_surface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivTaskType"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Write essay on Renaissance art" />

        <!-- Subject chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipSubject"
            style="@style/Widget.Material3.Chip.Suggestion"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textSize="11sp"
            app:layout_constraintStart_toEndOf="@id/ivTaskType"
            app:layout_constraintTop_toBottomOf="@id/tvTaskTitle"
            tools:text="History" />

        <!-- Due date -->
        <TextView
            android:id="@+id/tvDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_md"
            android:drawablePadding="4dp"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/on_surface_variant"
            app:drawableStartCompat="@drawable/ic_calendar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTaskTitle"
            tools:text="28 Apr, 14:00" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
